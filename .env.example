# Seed to Literature environment template
# Scope: variables actually used by codes/zotero/search/*

# ------------------------------
# Optional API etiquette
# ------------------------------
ZOTERO_SEARCH_MAILTO=your_email@example.com
# MAILTO=your_email@example.com

# ------------------------------
# Optional provider keys
# ------------------------------
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
# S2_API_KEY=your_semantic_scholar_api_key

OPENAI_API_KEY=your_openai_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# ------------------------------
# Required only for Zotero collection seed/import
# ------------------------------
ZOTERO_API_KEY=your_zotero_api_key
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=your_zotero_library_id

# ------------------------------
# Optional HTTP/retry tuning
# ------------------------------
ZOTERO_SEARCH_HTTP_RETRIES=2
ZOTERO_SEARCH_HTTP_POST_RETRIES=0
ZOTERO_SEARCH_HTTP_BACKOFF_BASE=0.8
ZOTERO_SEARCH_HTTP_BACKOFF_CAP=8.0
ZOTERO_SEARCH_HTTP_WARN=1
ZOTERO_SEARCH_USER_AGENT=myocean-zotero-search/0.1

# ------------------------------
# Optional Crossref throttling
# ------------------------------
ZOTERO_SEARCH_CROSSREF_MAX_LOOKUPS=60
ZOTERO_SEARCH_CROSSREF_DELAY_SECONDS=0.15
